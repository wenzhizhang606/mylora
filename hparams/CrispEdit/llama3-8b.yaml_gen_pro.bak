# Gen Pro 版 CrispEdit 配置
# 基于 Gen 方法 + KL 散度正则 + 闭式残差修正

alg_name: "CRISPEDIT"
device: 0
model_name: "Meta-Llama-3-8B-Instruct"

layers: [19, 20, 21, 22, 23]
num_steps: 25
batch_size: 32
max_length: 40
lr: 5e-4
weight_decay: 0
kl_factor: 0.01
norm_constraint: false
objective_optimization: "target_new"

rewrite_module_tmp: "model.layers.{}.mlp.down_proj.weight"
layer_module_tmp: "model.layers.{}"
mlp_module_tmp: "model.layers.{}.mlp"
attn_module_tmp: "model.layers.{}.self_attn"
ln_f_module: "model.norm"
lm_head_module: "lm_head"
model_parallel: false

# K-FAC 统计
mom2_dataset: "wikipedia"
mom2_n_samples: 10000
mom2_dtype: "float32"
energy_threshold: 0.8

# Gen 软 K-FAC 参数
soft_lambda: 1.0
factor_damping: 1.0e-5
use_second_projection: false
newton_damping: 1.0e-3

# 任务协方差（可选，用于 edit 因子）
task_mom2_dataset: "zsre_mend_163k"
task_mom2_n_samples: 10000

# 缓存路径（按需修改为本地路径）
base_kfac_cache_path: "/home/zwz/01_crispedit/Meta-Llama-3-8B-Instruct/wikipedia_stats"
task_kfac_cache_path: "/home/zwz/01_crispedit/Meta-Llama-3-8B-Instruct/zsre_mend_163k_stats"

# 运行时参数
edit_n_samples: 10
edit_cache_style: "mix"
recalculate_cache: false
recalculate_weight_threshold: 0.01
no_crisp: false
disable_old_loss_check: false
perform_lora: false
num_edits: 1

# === 改进 1：KL 散度正则参数 ===
kl_interval: 1

# === 改进 2：闭式残差修正参数 ===
nullspace_threshold: 0.02
L2: 1.0

# fact_token 用于编辑键计算（subject_last 策略）
fact_token: "subject_last"
clamp_norm_factor: 0.75
v_num_grad_steps: 25
v_lr: 0.1
v_loss_layer: 31
v_weight_decay: 0.5
mom2_adjustment: true
mom2_update_weight: 15000
layer_selection: "all"
